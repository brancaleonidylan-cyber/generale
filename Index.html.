      let safety = 0;
      while(evalExpr(whileM[1])){
        execBlock(idx+1, bodyEnd);
        if(++safety > 10000) throw new Error('ciclo infinito (oltre 10k iterazioni)');
      }
      return bodyEnd;
    }

    const defM = trimmed.match(/^def\s+(\w+)\((.*)\):$/);
    if(defM){
      const fname = defM[1];
      const params = defM[2].split(',').map(p => p.trim()).filter(Boolean).map(p => {
        const [name, def] = p.split('=').map(x => x.trim());
        return {name, def: def !== undefined ? def : undefined};
      });
      const innerIndent = indent + 1;
      const bodyStart = idx+1;
      const bodyEnd = findBlockEnd(bodyStart, innerIndent);
      env[fname] = (...args) => {
        const save = {};
        params.forEach((p, i) => { save[p.name] = env[p.name]; env[p.name] = args[i] !== undefined ? args[i] : (p.def !== undefined ? evalExpr(p.def) : undefined); });
        let retVal;
        try {
          let k = bodyStart;
          while(k < bodyEnd){
            if(isBlank(lines[k])){ k++; continue; }
            const t = lines[k].trim();
            if(t.startsWith('return ') || t === 'return'){
              retVal = t === 'return' ? undefined : evalExpr(t.slice(7));
              break;
            }
            k = execLine(k, bodyEnd);
          }
        } finally {
          params.forEach(p => { if(save[p.name] === undefined) delete env[p.name]; else env[p.name] = save[p.name]; });
        }
        return retVal;
      };
      return bodyEnd;
    }

    const assignM = trimmed.match(/^([a-zA-Z_àèìòùÀÈÌÒÙ][\w\[\]'"., àèìòùÀÈÌÒÙ]*?)\s*([+\-*/]?=)\s*(.+)$/);
    if(assignM && !trimmed.startsWith('if') && !trimmed.startsWith('while') && !trimmed.startsWith('for') && !trimmed.startsWith('def') && !trimmed.startsWith('return')){
      const target = assignM[1].trim();
      const op = assignM[2];
      const val = evalExpr(assignM[3]);
      if(/^[a-zA-Z_àèìòùÀÈÌÒÙ][\w àèìòùÀÈÌÒÙ]*$/.test(target)){
        const name = target.trim();
        if(op === '=') env[name] = val;
        else if(op === '+=') env[name] = env[name] + val;
        else if(op === '-=') env[name] = env[name] - val;
        else if(op === '*=') env[name] = env[name] * val;
        else if(op === '/=') env[name] = env[name] / val;
      } else {
        const m = target.match(/^(\w+)\[(.+)\]$/);
        if(m){
          const obj = env[m[1]];
          const key = evalExpr(m[2]);
          if(obj && obj.__df__){ obj.data[key] = val.__series__ ? val.data : (val.__array__ ? val.data : val); if(!obj.columns.includes(key)) obj.columns.push(key); }
          else if(obj && obj.__series__) obj.data[typeof key === 'number' ? key : obj.index.indexOf(key)] = val;
          else if(Array.isArray(obj) || typeof obj === 'object') obj[key] = val;
        }
      }
      return idx+1;
    }

    evalExpr(trimmed);
    return idx+1;
  }

  execBlock(0, lines.length);
  return output.join('\n');
}

document.addEventListener('keydown', (e) => {
  if((e.ctrlKey || e.metaKey) && e.key === 'k'){
    e.preventDefault();
    if(confirm('Reset dei tuoi progressi? Tutti gli esercizi salvati verranno persi.')){
      localStorage.removeItem(STORAGE_KEY);
      location.reload();
    }
  }
  if(e.key === 'ArrowDown' && e.altKey){
    const idx = LESSONS.findIndex(l => l.id === state.currentId);
    if(idx < LESSONS.length - 1) goLesson(LESSONS[idx+1].id);
  }
  if(e.key === 'ArrowUp' && e.altKey){
    const idx = LESSONS.findIndex(l => l.id === state.currentId);
    if(idx > 0) goLesson(LESSONS[idx-1].id);
  }
});

buildNav();
updateProgress();
const lesson = LESSONS.find(l => l.id === state.currentId) || LESSONS[0];
renderLesson(lesson);
</script>
