function renderLesson(l){
  const main = document.getElementById('main');
  let html = `<div class="page active">
    <div class="page-header">
      <div class="page-kicker">${l.kicker}</div>
      <div class="page-title">${l.title}</div>
      <div class="page-sub">${l.sub}</div>
    </div>`;
  l.content.forEach((c, i) => {
    if(c.type === 'card') html += renderCard(c);
    else if(c.type === 'editor') html += renderEditor(c, l.id, i);
    else if(c.type === 'exercises') html += renderExercises(c, l.id);
    else if(c.type === 'exercise') html += renderSingleExercise(c, l.id, i);
  });
  const idx = LESSONS.findIndex(x => x.id === l.id);
  const prev = LESSONS[idx-1];
  const next = LESSONS[idx+1];
  html += `<div class="nav-controls">
    ${prev ? `<button class="btn btn-ghost" onclick="goLesson('${prev.id}')">← ${prev.title}</button>` : `<span></span>`}
    <button class="btn btn-primary" onclick="markDone('${l.id}')">Segna come completata ✓</button>
    ${next ? `<button class="btn btn-ghost" onclick="goLesson('${next.id}')">${next.title} →</button>` : `<span></span>`}
  </div></div>`;
  main.innerHTML = html;
  main.querySelectorAll('.editor').forEach(ed => {
    ed.addEventListener('input', () => { state.editors[ed.id] = ed.value; saveState(); });
    ed.addEventListener('keydown', (e) => {
      if((e.ctrlKey || e.metaKey) && e.key === 'Enter'){ e.preventDefault(); runEditor(ed.id); }
      if(e.key === 'Tab'){ e.preventDefault(); const s=ed.selectionStart,E=ed.selectionEnd; ed.value=ed.value.substring(0,s)+'    '+ed.value.substring(E); ed.selectionStart=ed.selectionEnd=s+4; }
    });
  });
  window.scrollTo(0, 0);
}

function goLesson(id){
  state.currentId = id;
  saveState();
  buildNav();
  const l = LESSONS.find(x => x.id === id);
  if(l) renderLesson(l);
}

function markDone(id){
  state.done.add(id);
  saveState();
  updateProgress();
  buildNav();
  const idx = LESSONS.findIndex(x => x.id === id);
  if(idx < LESSONS.length - 1){ setTimeout(() => goLesson(LESSONS[idx+1].id), 400); }
}

function toggle(id){ const el = document.getElementById(id); if(el) el.classList.toggle('show'); }

function resetEditor(id, code){
  const ed = document.getElementById(id);
  ed.value = code;
  delete state.editors[id];
  saveState();
  clearOutput(id);
}

function loadSolution(id, code){
  const ed = document.getElementById(id);
  ed.value = code;
  state.editors[id] = code;
  saveState();
}

function clearOutput(id){
  const out = document.getElementById(id + '-out');
  if(out){ out.textContent = "L'output apparirà qui."; out.className = 'output out-empty'; }
}

function runEditor(id){
  const code = document.getElementById(id).value;
  const out = document.getElementById(id + '-out');
  try{
    const result = pyEval(code);
    out.textContent = result || '(nessun output — aggiungi print() per vedere i valori)';
    out.className = 'output ' + (result ? 'out-ok' : 'out-empty');
  }catch(e){
    out.textContent = 'Errore: ' + e.message;
    out.className = 'output out-err';
  }
}

function pyEval(code){
  const output = [];
  const env = Object.create(null);
  const npNS = Object.create(null);
  const pdNS = Object.create(null);
  let npImported = false, pdImported = false;

  function pyRepr(v, top){
    if(v === true) return 'True';
    if(v === false) return 'False';
    if(v === null || v === undefined) return 'None';
    if(typeof v === 'string') return top ? v : "'" + v + "'";
    if(typeof v === 'number'){
      if(Number.isNaN(v)) return 'nan';
      if(Number.isInteger(v)) return String(v);
      return String(v);
    }
    if(v && v.__array__){
      return 'array(' + arrRepr(v.data, v.shape) + ')';
    }
    if(v && v.__series__){
      let s = '';
      const idx = v.index, vals = v.data;
      const maxIdxLen = Math.max(...idx.map(x => String(x).length));
      for(let i = 0; i < idx.length; i++){
        s += String(idx[i]).padEnd(maxIdxLen + 4) + formatNum(vals[i]) + '\n';
      }
      if(v.name) s += 'Name: ' + v.name + ', ';
      s += 'dtype: ' + v.dtype;
      return s;
    }
    if(v && v.__df__){
      return dfRepr(v);
    }
    if(Array.isArray(v)){
      return '[' + v.map(x => pyRepr(x)).join(', ') + ']';
    }
    if(typeof v === 'object'){
      return '{' + Object.entries(v).map(([k,val]) => "'"+k+"': "+pyRepr(val)).join(', ') + '}';
    }
    return String(v);
  }

  function formatNum(n){
    if(typeof n !== 'number') return String(n);
    if(Number.isNaN(n)) return 'NaN';
    if(Number.isInteger(n)) return String(n);
    return String(Math.round(n * 1e10) / 1e10);
  }

  function arrRepr(data, shape){
    if(shape.length === 1){
      return '[' + data.map(formatNum).join(', ') + ']';
    }
    const [rows, cols] = shape;
    let s = '[';
    for(let i = 0; i < rows; i++){
      s += '[' + data.slice(i*cols, (i+1)*cols).map(formatNum).join(', ') + ']';
      if(i < rows-1) s += ',\n       ';
    }
    s += ']';
    return s;
  }

  function dfRepr(df){
    const cols = df.columns;
    const idx = df.index;
    const widths = cols.map(c => Math.max(String(c).length, ...df.data[c].map(v => String(formatNum(v)).length)));
    const idxW = Math.max(...idx.map(x => String(x).length));
    let s = ' '.repeat(idxW + 2);
    cols.forEach((c, i) => { s += String(c).padStart(widths[i] + 2); });
    s += '\n';
    for(let r = 0; r < idx.length; r++){
      s += String(idx[r]).padEnd(idxW + 2);
      cols.forEach((c, i) => { s += String(formatNum(df.data[c][r])).padStart(widths[i] + 2); });
      s += '\n';
    }
    return s.trimEnd();
  }

  function makeArray(data, shape){
    if(!shape){ shape = [data.length]; }
    const flat = Array.isArray(data[0]) ? data.flat() : data;
    const arr = {
      __array__: true,
      data: flat,
      shape: shape,
      get ndim(){ return shape.length; },
      get size(){ return flat.length; },
      dtype: flat.some(x => !Number.isInteger(x)) ? 'float64' : 'int64',
      sum(opts){
        if(!opts || opts.axis === undefined) return flat.reduce((a,b)=>a+b,0);
        if(shape.length !== 2) return flat.reduce((a,b)=>a+b,0);
        const [r, c] = shape;
        if(opts.axis === 0){ const res = new Array(c).fill(0); for(let i=0;i<r;i++)for(let j=0;j<c;j++)res[j]+=flat[i*c+j]; return makeArray(res,[c]); }
        if(opts.axis === 1){ const res = []; for(let i=0;i<r;i++){let s=0;for(let j=0;j<c;j++)s+=flat[i*c+j];res.push(s);} return makeArray(res,[r]); }
      },
      mean(opts){
        if(!opts || opts.axis === undefined) return flat.reduce((a,b)=>a+b,0)/flat.length;
        const s = arr.sum(opts);
        const n = opts.axis === 0 ? shape[0] : shape[1];
        return makeArray(s.data.map(x => x/n), s.shape);
      },
      max(opts){
        if(!opts || opts.axis === undefined) return Math.max(...flat);
        if(shape.length !== 2) return Math.max(...flat);
        const [r, c] = shape;
        if(opts.axis === 0){ const res = []; for(let j=0;j<c;j++){let m=-Infinity;for(let i=0;i<r;i++)m=Math.max(m,flat[i*c+j]);res.push(m);} return makeArray(res,[c]); }
        if(opts.axis === 1){ const res = []; for(let i=0;i<r;i++){let m=-Infinity;for(let j=0;j<c;j++)m=Math.max(m,flat[i*c+j]);res.push(m);} return makeArray(res,[r]); }
      },
      min(opts){
        if(!opts || opts.axis === undefined) return Math.min(...flat);
        if(shape.length !== 2) return Math.min(...flat);
        const [r, c] = shape;
        if(opts.axis === 0){ const res = []; for(let j=0;j<c;j++){let m=Infinity;for(let i=0;i<r;i++)m=Math.min(m,flat[i*c+j]);res.push(m);} return makeArray(res,[c]); }
        if(opts.axis === 1){ const res = []; for(let i=0;i<r;i++){let m=Infinity;for(let j=0;j<c;j++)m=Math.min(m,flat[i*c+j]);res.push(m);} return makeArray(res,[r]); }
      },
      std(opts){
        const calc = (arr) => { const m = arr.reduce((a,b)=>a+b,0)/arr.length; return Math.sqrt(arr.reduce((a,b)=>a+(b-m)**2,0)/arr.length); };
        if(!opts || opts.axis === undefined) return calc(flat);
        if(shape.length !== 2) return calc(flat);
        const [r, c] = shape;
        if(opts.axis === 0){ const res = []; for(let j=0;j<c;j++){const col=[];for(let i=0;i<r;i++)col.push(flat[i*c+j]);res.push(calc(col));} return makeArray(res,[c]); }
        if(opts.axis === 1){ const res = []; for(let i=0;i<r;i++)res.push(calc(flat.slice(i*c,(i+1)*c))); return makeArray(res,[r]); }
      },
      argmax(){ let m = -Infinity, idx = 0; flat.forEach((v,i) => { if(v > m){m=v;idx=i;}}); return idx; },
      argmin(){ let m = Infinity, idx = 0; flat.forEach((v,i) => { if(v < m){m=v;idx=i;}}); return idx; },
      round(d=0){ return makeArray(flat.map(v => +v.toFixed(d)), shape); }
    };
    return arr;
  }

  function arrOp(a, b, op){
    const aArr = a && a.__array__;
    const bArr = b && b.__array__;
    if(aArr && bArr){
      if(a.shape.length === b.shape.length && a.shape.every((s,i)=>s===b.shape[i])){
        return makeArray(a.data.map((v,i)=>op(v,b.data[i])), a.shape);
      }
      if(a.shape.length === 2 && b.shape.length === 1 && a.shape[1] === b.shape[0]){
        const [r,c] = a.shape; const res = new Array(r*c);
        for(let i=0;i<r;i++)for(let j=0;j<c;j++)res[i*c+j] = op(a.data[i*c+j], b.data[j]);
        return makeArray(res, a.shape);
      }
    }
    if(aArr) return makeArray(a.data.map(v => op(v,b)), a.shape);
    if(bArr) return makeArray(b.data.map(v => op(a,v)), b.shape);
    return op(a,b);
  }

  npNS.array = (data) => {
    if(Array.isArray(data) && Array.isArray(data[0])){
      return makeArray(data, [data.length, data[0].length]);
    }
    return makeArray(data);
  };
  npNS.zeros = (shape) => { const n = Array.isArray(shape) ? shape.reduce((a,b)=>a*b,1) : shape; return makeArray(new Array(n).fill(0), Array.isArray(shape) ? shape : [shape]); };
  npNS.ones = (shape) => { const n = Array.isArray(shape) ? shape.reduce((a,b)=>a*b,1) : shape; return makeArray(new Array(n).fill(1), Array.isArray(shape) ? shape : [shape]); };
  npNS.arange = (start, stop, step) => { if(stop === undefined){stop=start;start=0;} if(step===undefined)step=1; const res=[]; for(let i=start;i<stop;i+=step)res.push(i); return makeArray(res); };
  npNS.linspace = (start, stop, n) => { const res=[], step=(stop-start)/(n-1); for(let i=0;i<n;i++)res.push(start+step*i); return makeArray(res); };
  npNS.sum = (a) => a.__array__ ? a.sum() : a.reduce((x,y)=>x+y,0);
  npNS.mean = (a) => a.__array__ ? a.mean() : a.reduce((x,y)=>x+y,0)/a.length;
  npNS.max = (a) => a.__array__ ? a.max() : Math.max(...a);
  npNS.min = (a) => a.__array__ ? a.min() : Math.min(...a);
  npNS.median = (a) => { const d = (a.__array__ ? a.data : a).slice().sort((x,y)=>x-y); const n = d.length; return n%2 ? d[(n-1)/2] : (d[n/2-1]+d[n/2])/2; };
  npNS.sqrt = (a) => a.__array__ ? makeArray(a.data.map(Math.sqrt), a.shape) : Math.sqrt(a);
  npNS.log = (a) => a.__array__ ? makeArray(a.data.map(Math.log), a.shape) : Math.log(a);
  npNS.round = (a, d=0) => a.__array__ ? a.round(d) : +a.toFixed(d);
  npNS.where = (cond, a, b) => {
    if(cond.__array__){
      const ad = a && a.__array__ ? a.data : null;
      const bd = b && b.__array__ ? b.data : null;
      return makeArray(cond.data.map((c,i) => c ? (ad ? ad[i] : a) : (bd ? bd[i] : b)), cond.shape);
    }
    return cond ? a : b;
  };
  npNS.unique = (a, opts) => {
    const arr = a.__array__ ? a.data : a;
    const counts = {};
    arr.forEach(v => { counts[v] = (counts[v]||0) + 1; });
    const keys = Object.keys(counts).sort();
    if(opts && opts.return_counts){
      return [makeArray(keys.map(k => isNaN(k) ? k : +k)), makeArray(keys.map(k => counts[k]))];
    }
    return makeArray(keys.map(k => isNaN(k) ? k : +k));
  };
  npNS.percentile = (a, p) => { const d = (a.__array__ ? a.data : a).slice().sort((x,y)=>x-y); const idx = (p/100) * (d.length-1); const lo = Math.floor(idx), hi = Math.ceil(idx); return d[lo] + (d[hi]-d[lo])*(idx-lo); };
  npNS.sort = (a) => { const d = (a.__array__ ? a.data : a).slice().sort((x,y)=>x-y); return makeArray(d); };
  npNS.random = {
    seed: (s) => { npNS.random._seed = s; },
    _seed: 1,
    _rng: function(){ this._seed = (this._seed * 9301 + 49297) % 233280; return this._seed / 233280; },
    rand: function(n){ const r=[]; for(let i=0;i<n;i++)r.push(this._rng()); return makeArray(r); },
    uniform: function(lo, hi, n){ const r=[]; for(let i=0;i<n;i++)r.push(lo + this._rng()*(hi-lo)); return makeArray(r); },
    randint: function(lo, hi, n){ const r=[]; for(let i=0;i<n;i++)r.push(Math.floor(lo + this._rng()*(hi-lo))); return makeArray(r); },
    choice: function(arr, n){ const src = arr.__array__ ? arr.data : arr; const r=[]; for(let i=0;i<n;i++)r.push(src[Math.floor(this._rng()*src.length)]); return makeArray(r); },
    poisson: function(lam, n){ const r=[]; for(let i=0;i<n;i++){let L=Math.exp(-lam),k=0,p=1; do{k++;p*=this._rng();}while(p>L); r.push(k-1);} return makeArray(r); }
  };

  function makeSeries(data, index, name){
    const vals = data.__array__ ? data.data : (Array.isArray(data) ? data : [data]);
    const idx = index || vals.map((_,i)=>i);
    return {
      __series__: true,
      data: vals,
      index: idx,
      name: name || null,
      dtype: vals.some(v => !Number.isInteger(v) && typeof v === 'number') ? 'float64' : (vals.every(v => typeof v === 'number') ? 'int64' : 'object'),
      get size(){ return vals.length; },
      get values(){ return makeArray(vals); },
      sum(){ return vals.filter(v => typeof v === 'number').reduce((a,b)=>a+b,0); },
      mean(){ const f = vals.filter(v => typeof v === 'number'); return f.reduce((a,b)=>a+b,0)/f.length; },
      max(){ return Math.max(...vals.filter(v=>typeof v==='number')); },
      min(){ return Math.min(...vals.filter(v=>typeof v==='number')); },
      count(){ return vals.filter(v => v !== null && !Number.isNaN(v)).length; },
      describe(){
        const v = vals.filter(x=>typeof x==='number').slice().sort((a,b)=>a-b);
        const mean = v.reduce((a,b)=>a+b,0)/v.length;
        const std = Math.sqrt(v.reduce((a,b)=>a+(b-mean)**2,0)/v.length);
        return makeSeries([v.length, mean, std, v[0], v[Math.floor(v.length*0.25)], v[Math.floor(v.length*0.5)], v[Math.floor(v.length*0.75)], v[v.length-1]], ['count','mean','std','min','25%','50%','75%','max']);
      }
    };
  }

  pdNS.Series = (data, opts) => {
    opts = opts || {};
    return makeSeries(data, opts.index, opts.name);
  };

  function makeDF(dataDict, index){
