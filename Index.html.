<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Python per Business Analyst — Laboratorio completo</title>
<style>
:root{
  --bg:#FAFAF7;--surface:#FFFFFF;--surface-2:#F1EFE8;--text:#2C2C2A;--text-2:#5F5E5A;--text-3:#888780;
  --border:#D3D1C7;--border-2:#B4B2A9;
  --purple:#3C3489;--purple-l:#EEEDFE;--purple-m:#AFA9EC;
  --teal:#0F6E56;--teal-l:#E1F5EE;--teal-m:#5DCAA5;
  --amber:#633806;--amber-l:#FAEEDA;--amber-m:#EF9F27;
  --blue:#0C447C;--blue-l:#E6F1FB;--blue-m:#85B7EB;
  --coral:#712B13;--coral-l:#FAECE7;--coral-m:#F0997B;
  --green:#27500A;--green-l:#EAF3DE;--green-m:#97C459;
  --red:#791F1F;--red-l:#FCEBEB;--red-m:#F09595;
  --pink:#72243E;--pink-l:#FBEAF0;--pink-m:#ED93B1;
  --radius:8px;--radius-lg:12px;
  --mono:'SF Mono', Monaco, Menlo, Consolas, 'Courier New', monospace;
  --sans:-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}
@media(prefers-color-scheme:dark){
  :root{
    --bg:#1A1A18;--surface:#26261F;--surface-2:#2C2C24;--text:#E8E6DC;--text-2:#B4B2A9;--text-3:#888780;
    --border:#3D3D36;--border-2:#4A4A42;
    --purple-l:#26215C;--teal-l:#04342C;--amber-l:#412402;--blue-l:#042C53;
    --coral-l:#4A1B0C;--green-l:#173404;--red-l:#501313;--pink-l:#4B1528;
  }
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:var(--sans);background:var(--bg);color:var(--text);line-height:1.6;min-height:100vh;}
.app{display:grid;grid-template-columns:280px 1fr;min-height:100vh;}
.sidebar{background:var(--surface);border-right:0.5px solid var(--border);padding:20px 16px;overflow-y:auto;position:sticky;top:0;height:100vh;}
.sidebar-header{padding:0 8px 16px;border-bottom:0.5px solid var(--border);margin-bottom:16px;}
.logo{font-size:16px;font-weight:600;color:var(--text);margin-bottom:4px;}
.logo-sub{font-size:12px;color:var(--text-2);}
.progress-global{margin:14px 0 8px;}
.progress-label{font-size:11px;color:var(--text-2);margin-bottom:5px;display:flex;justify-content:space-between;}
.progress-bar-wrap{height:5px;background:var(--surface-2);border-radius:10px;overflow:hidden;}
.progress-bar{height:100%;background:linear-gradient(90deg,var(--purple) 0%,var(--teal) 100%);transition:width 0.4s;}
.phase-list{list-style:none;}
.phase-group{margin-bottom:6px;}
.phase-header{padding:8px 10px;font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:0.05em;}
.phase-item{display:flex;align-items:center;gap:10px;padding:8px 10px;font-size:13px;color:var(--text-2);cursor:pointer;border-radius:var(--radius);transition:all 0.15s;border:none;background:none;width:100%;text-align:left;font-family:inherit;}
.phase-item:hover{background:var(--surface-2);color:var(--text);}
.phase-item.active{background:var(--purple-l);color:var(--purple);font-weight:500;}
.phase-item.done{color:var(--teal);}
.phase-dot{width:18px;height:18px;border-radius:50%;background:var(--surface-2);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;color:var(--text-3);flex-shrink:0;}
.phase-item.active .phase-dot{background:var(--purple);color:#fff;}
.phase-item.done .phase-dot{background:var(--teal);color:#fff;}
.phase-item.done .phase-dot::after{content:'✓';}
.phase-item.done .phase-num{display:none;}
.main{padding:32px 40px;max-width:1000px;overflow-x:hidden;}
.page{display:none;animation:fade 0.3s ease;}
.page.active{display:block;}
@keyframes fade{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}
.page-header{margin-bottom:24px;padding-bottom:16px;border-bottom:0.5px solid var(--border);}
.page-kicker{font-size:12px;color:var(--purple);font-weight:600;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:6px;}
.page-title{font-size:26px;font-weight:600;color:var(--text);margin-bottom:8px;}
.page-sub{font-size:14px;color:var(--text-2);max-width:680px;line-height:1.7;}
.section{margin-bottom:32px;}
.section-title{font-size:18px;font-weight:600;color:var(--text);margin-bottom:4px;display:flex;align-items:center;gap:10px;}
.section-sub{font-size:13px;color:var(--text-2);margin-bottom:16px;line-height:1.6;}
.card{background:var(--surface);border:0.5px solid var(--border);border-radius:var(--radius-lg);padding:16px 20px;margin-bottom:14px;}
.card-title{font-size:14px;font-weight:600;color:var(--text);margin-bottom:8px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.card-body{font-size:13.5px;color:var(--text-2);line-height:1.75;margin-bottom:10px;}
.card-body strong{color:var(--text);font-weight:600;}
.badge{display:inline-block;padding:2px 9px;border-radius:6px;font-size:11px;font-weight:600;letter-spacing:0.01em;}
.b-purple{background:var(--purple-l);color:var(--purple);}
.b-teal{background:var(--teal-l);color:var(--teal);}
.b-amber{background:var(--amber-l);color:var(--amber);}
.b-blue{background:var(--blue-l);color:var(--blue);}
.b-coral{background:var(--coral-l);color:var(--coral);}
.b-green{background:var(--green-l);color:var(--green);}
.b-red{background:var(--red-l);color:var(--red);}
.b-pink{background:var(--pink-l);color:var(--pink);}
.code{background:var(--surface-2);border-radius:var(--radius);padding:12px 14px;font-family:var(--mono);font-size:13px;line-height:1.7;white-space:pre;overflow-x:auto;margin:8px 0;border:0.5px solid var(--border);}
code.inline{background:var(--surface-2);padding:1px 6px;border-radius:4px;font-family:var(--mono);font-size:12.5px;color:var(--text);}
.kw{color:var(--purple);font-weight:600;}
.str{color:var(--teal);}
.num{color:var(--amber);}
.cm{color:var(--text-3);font-style:italic;}
.fn{color:var(--blue);}
.note{border-left:3px solid var(--purple-m);background:var(--purple-l);padding:10px 14px;border-radius:0 var(--radius) var(--radius) 0;font-size:13px;color:var(--purple);margin:10px 0;line-height:1.7;}
.warn{border-left:3px solid var(--amber-m);background:var(--amber-l);padding:10px 14px;border-radius:0 var(--radius) var(--radius) 0;font-size:13px;color:var(--amber);margin:10px 0;line-height:1.7;}
.ok{border-left:3px solid var(--teal-m);background:var(--teal-l);padding:10px 14px;border-radius:0 var(--radius) var(--radius) 0;font-size:13px;color:var(--teal);margin:10px 0;line-height:1.7;}
.err{border-left:3px solid var(--red-m);background:var(--red-l);padding:10px 14px;border-radius:0 var(--radius) var(--radius) 0;font-size:13px;color:var(--red);margin:10px 0;line-height:1.7;}
.pro-tip{border-left:3px solid var(--coral-m);background:var(--coral-l);padding:10px 14px;border-radius:0 var(--radius) var(--radius) 0;font-size:13px;color:var(--coral);margin:10px 0;line-height:1.7;}
.pro-tip::before{content:'⚡ PRO TIP ';font-weight:700;letter-spacing:0.03em;}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.grid3{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px;}
@media(max-width:700px){.grid2,.grid3{grid-template-columns:1fr;}.app{grid-template-columns:1fr;}.sidebar{position:relative;height:auto;}.main{padding:20px;}}
.editor-wrap{margin:12px 0;}
.editor-bar{display:flex;justify-content:space-between;align-items:center;padding:6px 10px;background:var(--surface-2);border:0.5px solid var(--border);border-bottom:none;border-radius:var(--radius) var(--radius) 0 0;font-size:11px;color:var(--text-2);}
.editor{width:100%;min-height:140px;padding:12px 14px;border:0.5px solid var(--border);border-top:none;border-radius:0 0 var(--radius) var(--radius);background:var(--surface);font-family:var(--mono);font-size:13px;color:var(--text);line-height:1.7;resize:vertical;outline:none;tab-size:4;}
.editor:focus{border-color:var(--purple-m);box-shadow:0 0 0 2px rgba(127,119,221,0.15);}
.btn-row{display:flex;gap:8px;margin-top:10px;align-items:center;flex-wrap:wrap;}
.btn{padding:7px 16px;border-radius:var(--radius);font-size:13px;cursor:pointer;font-weight:500;border:none;font-family:inherit;transition:all 0.15s;}
.btn-primary{background:var(--purple);color:#fff;}
.btn-primary:hover{background:#2a2466;}
.btn-ghost{background:transparent;color:var(--text-2);border:0.5px solid var(--border);}
.btn-ghost:hover{background:var(--surface-2);color:var(--text);}
.output{margin-top:10px;padding:12px 14px;border-radius:var(--radius);font-family:var(--mono);font-size:12.5px;min-height:40px;line-height:1.7;white-space:pre-wrap;border:0.5px solid var(--border);}
.out-ok{background:var(--teal-l);color:var(--teal);border-color:var(--teal-m);}
.out-err{background:var(--red-l);color:var(--red);border-color:var(--red-m);}
.out-empty{background:var(--surface-2);color:var(--text-3);}
.tbl{width:100%;border-collapse:collapse;font-size:13px;margin:10px 0;border-radius:var(--radius);overflow:hidden;border:0.5px solid var(--border);}
.tbl th{text-align:left;padding:10px 12px;background:var(--surface-2);font-weight:600;color:var(--text);font-size:12px;border-bottom:0.5px solid var(--border);}
.tbl td{padding:9px 12px;border-top:0.5px solid var(--border);}
.tbl td.c{font-family:var(--mono);font-size:12px;color:var(--text);}
.tbl tr:hover{background:var(--surface-2);}
.mem-viz{display:flex;gap:8px;flex-wrap:wrap;margin:12px 0;padding:14px;background:var(--surface-2);border-radius:var(--radius);}
.mem-cell{background:var(--surface);border:1.5px solid var(--purple-m);border-radius:var(--radius);padding:8px 12px;min-width:80px;text-align:center;}
.mem-label{font-size:10px;color:var(--text-3);margin-bottom:3px;text-transform:uppercase;letter-spacing:0.05em;}
.mem-val{font-family:var(--mono);font-size:13px;font-weight:600;color:var(--purple);}
.mem-type{font-size:10px;color:var(--text-3);margin-top:2px;}
.ex-card{background:var(--surface);border:0.5px solid var(--border);border-radius:var(--radius-lg);padding:18px 22px;margin-bottom:16px;position:relative;}
.ex-head{display:flex;justify-content:space-between;align-items:start;gap:12px;margin-bottom:10px;flex-wrap:wrap;}
.ex-title{font-size:14px;font-weight:600;color:var(--text);}
.ex-tag{font-size:10px;padding:3px 8px;border-radius:5px;font-weight:600;letter-spacing:0.03em;text-transform:uppercase;}
.ex-easy{background:var(--green-l);color:var(--green);}
.ex-med{background:var(--amber-l);color:var(--amber);}
.ex-hard{background:var(--red-l);color:var(--red);}
.ex-biz{background:var(--purple-l);color:var(--purple);}
.ex-desc{font-size:13px;color:var(--text-2);margin-bottom:10px;line-height:1.7;}
.hint-btn{font-size:12px;color:var(--purple);cursor:pointer;background:none;border:none;padding:0;text-decoration:underline;font-family:inherit;}
.hint{display:none;margin-top:8px;padding:9px 12px;font-size:12.5px;color:var(--purple);background:var(--purple-l);border-radius:var(--radius);line-height:1.7;}
.hint.show{display:block;}
.solution-btn{font-size:12px;color:var(--teal);cursor:pointer;background:none;border:none;padding:0;text-decoration:underline;font-family:inherit;margin-left:14px;}
.sol{display:none;margin-top:8px;padding:10px 12px;font-size:12.5px;color:var(--teal);background:var(--teal-l);border-radius:var(--radius);}
.sol.show{display:block;}
.sol pre{font-family:var(--mono);font-size:12px;white-space:pre-wrap;margin-top:4px;line-height:1.6;}
.nav-controls{display:flex;justify-content:space-between;align-items:center;padding:20px;margin-top:30px;border-top:0.5px solid var(--border);}
.shortcut{font-family:var(--mono);font-size:11px;background:var(--surface-2);color:var(--text-2);padding:2px 6px;border-radius:4px;border:0.5px solid var(--border);}
.concept-row{display:flex;gap:10px;align-items:start;padding:12px;background:var(--surface-2);border-radius:var(--radius);margin:8px 0;}
.concept-num{background:var(--purple);color:#fff;width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0;}
.concept-text{font-size:13px;color:var(--text-2);line-height:1.7;}
.flashcard{background:var(--surface);border:0.5px solid var(--border);border-radius:var(--radius-lg);padding:14px 18px;margin:8px 0;cursor:pointer;transition:all 0.15s;}
.flashcard:hover{border-color:var(--purple-m);}
.flashcard-q{font-size:13px;font-weight:600;color:var(--text);margin-bottom:6px;}
.flashcard-a{display:none;font-size:12.5px;color:var(--text-2);padding-top:8px;margin-top:8px;border-top:0.5px solid var(--border);line-height:1.7;}
.flashcard.open .flashcard-a{display:block;}
.flashcard-toggle{font-size:11px;color:var(--purple);font-weight:500;}
.stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin:16px 0;}
.stat-card{background:var(--surface-2);border-radius:var(--radius);padding:12px 14px;}
.stat-label{font-size:11px;color:var(--text-2);margin-bottom:4px;text-transform:uppercase;letter-spacing:0.05em;}
.stat-val{font-size:22px;font-weight:600;color:var(--text);}
.stat-sub{font-size:11px;color:var(--text-3);margin-top:2px;}
.toc{background:var(--surface-2);border-radius:var(--radius);padding:14px 18px;margin-bottom:20px;}
.toc-title{font-size:12px;font-weight:600;color:var(--text-2);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:8px;}
.toc-list{list-style:none;}
.toc-list li{padding:4px 0;font-size:13px;color:var(--text-2);}
.toc-list li::before{content:'→ ';color:var(--purple-m);}
.kb{display:inline-flex;gap:4px;align-items:center;}
.key{font-family:var(--mono);font-size:11px;padding:2px 7px;background:var(--surface);border:0.5px solid var(--border);border-bottom:1.5px solid var(--border-2);border-radius:4px;color:var(--text);}
.sidebar-toggle{display:none;position:fixed;top:10px;left:10px;z-index:100;background:var(--surface);border:0.5px solid var(--border);border-radius:var(--radius);padding:6px 10px;font-size:18px;cursor:pointer;}
@media(max-width:700px){.sidebar-toggle{display:block;}.sidebar{position:fixed;z-index:50;width:260px;transform:translateX(-100%);transition:transform 0.3s;}.sidebar.open{transform:none;}}
</style>
</head>
<body>
<button class="sidebar-toggle" onclick="document.getElementById('sb').classList.toggle('open')">☰</button>
<div class="app">
<aside class="sidebar" id="sb">
  <div class="sidebar-header">
    <div class="logo">Python BA Lab</div>
    <div class="logo-sub">Da zero a Business Analyst</div>
    <div class="progress-global">
      <div class="progress-label"><span>Progresso totale</span><span id="pg-pct">0%</span></div>
      <div class="progress-bar-wrap"><div class="progress-bar" id="pg-bar" style="width:0%"></div></div>
      <div class="progress-label" style="margin-top:4px;"><span id="pg-count">0 / 38 lezioni</span></div>
    </div>
  </div>
  <nav class="phase-list" id="nav"></nav>
  <div style="padding:14px 10px;margin-top:10px;border-top:0.5px solid var(--border);font-size:11px;color:var(--text-3);line-height:1.6;">
    <div style="margin-bottom:6px;font-weight:600;color:var(--text-2);">Scorciatoie</div>
    <div><span class="shortcut">Ctrl+↵</span> Esegui codice</div>
    <div><span class="shortcut">↑ ↓</span> Naviga lezioni</div>
    <div><span class="shortcut">Ctrl+K</span> Reset sezione</div>
  </div>
</aside>
<main class="main" id="main"></main>
</div>
<script id="lessons-data" type="application/json">[{"phase": 1, "id": "p1-l1", "phaseName": "Fondamenta", "title": "Variabili — il mattone di tutto", "kicker": "Fase 1 · Lezione 1 di 5", "sub": "Una variabile è uno spazio nella memoria a cui dai un nome. È il concetto più importante di tutta la programmazione: se lo capisci bene, il resto scorre.", "content": [{"type": "card", "badge": "b-purple", "badgeTxt": "Regola #1", "title": "Il simbolo = non è 'uguale' matematico", "body": "In Python <code class='inline'>=</code> significa <strong>metti dentro</strong>. Non è un'uguaglianza: è un'azione. Leggi sempre da destra verso sinistra: calcola il valore a destra, mettilo nella scatola a sinistra.", "code": "<span class='kw'>nome</span> = <span class='str'>\"Marco\"</span>       <span class='cm'># metti \"Marco\" nella scatola 'nome'</span>\n<span class='kw'>età</span>  = <span class='num'>25</span>             <span class='cm'># metti 25 nella scatola 'età'</span>\n<span class='kw'>x</span>    = <span class='num'>10</span> + <span class='num'>5</span>         <span class='cm'># calcola 10+5=15, poi metti 15 in 'x'</span>", "warn": "Attenzione cruciale: <strong>= assegna</strong>, <strong>== confronta</strong>. Sono due cose diverse. Lo vediamo tra poco."}, {"type": "card", "badge": "b-teal", "badgeTxt": "Visuale", "title": "Come funziona la memoria", "body": "Quando scrivi <code class='inline'>nome = \"Marco\"</code>, Python riserva uno spazio in memoria, scrive \"Marco\" dentro e attacca l'etichetta \"nome\" a quello spazio.", "memory": [{"label": "nome", "val": "\"Marco\"", "type": "str"}, {"label": "età", "val": "25", "type": "int"}, {"label": "attivo", "val": "True", "type": "bool"}]}, {"type": "card", "badge": "b-amber", "badgeTxt": "Naming", "title": "Come si chiamano le variabili", "body": "Python ha convenzioni precise. Seguirle non è opzionale: è il modo in cui ti riconoscono come professionista.", "grid2": [{"title": "Corretto", "body": "<code class='inline'>nome = \"Marco\"</code><br><code class='inline'>età_utente = 25</code><br><code class='inline'>prezzo_totale = 99.9</code><br><code class='inline'>is_attivo = True</code>", "type": "ok"}, {"title": "Sbagliato", "body": "<code class='inline'>1numero = 42</code> (inizia con cifra)<br><code class='inline'>nome completo = \"M\"</code> (ha spazio)<br><code class='inline'>for = 5</code> (parola riservata)<br><code class='inline'>Prezzo-Totale = 9</code> (trattino)", "type": "err"}], "proTip": "Convenzione Python: <strong>snake_case</strong> — tutto minuscolo con underscore. Es: <code class='inline'>ricavo_mensile</code>. Per costanti <strong>MAIUSCOLO</strong>: <code class='inline'>TASSO_IVA = 0.22</code>."}, {"type": "editor", "title": "Prova tu: crea le tue prime variabili", "code": "# Crea variabili con i tuoi dati personali\nnome = \"Marco\"\netà = 25\ncittà = \"Bologna\"\nstipendio = 2500.50\nattivo = True\n\nprint(nome)\nprint(età)\nprint(città)\nprint(stipendio)\nprint(attivo)"}]}, {"phase": 1, "id": "p1-l2", "phaseName": "Fondamenta", "title": "Tipi di dato — cosa metti nella scatola", "kicker": "Fase 1 · Lezione 2 di 5", "sub": "Ogni valore ha un tipo. Il tipo decide cosa puoi farci. Nel mondo business analyst i tipi sbagliati sono la causa #1 di report errati.", "content": [{"type": "card", "badge": "b-purple", "badgeTxt": "I 4 tipi base", "body": "Python assegna il tipo automaticamente quando crei una variabile. Questi sono i 4 tipi che userai il 95% del tempo.", "types": [{"name": "str — stringa", "desc": "Qualsiasi testo. Sempre tra virgolette (singole o doppie).", "example": "\"Marco\", 'Bologna', \"Q1 2024\""}, {"name": "int — intero", "desc": "Numero senza decimali, positivo o negativo.", "example": "25, -10, 0, 1000000"}, {"name": "float — decimale", "desc": "Numero con la virgola. In Python si usa il punto (non la virgola).", "example": "2500.50, 3.14, -0.5"}, {"name": "bool — booleano", "desc": "Solo due valori: True o False. Maiuscola obbligatoria.", "example": "True, False"}], "warn": "Errore classico: scrivere <code class='inline'>true</code> invece di <code class='inline'>True</code>. Python è case-sensitive: <strong>t</strong> minuscola non funziona."}, {"type": "card", "badge": "b-teal", "badgeTxt": "type()", "title": "Scoprire il tipo di qualsiasi cosa", "body": "La funzione <code class='inline'>type()</code> ti dice il tipo di qualunque valore. È lo strumento #1 per fare debug quando qualcosa non torna.", "code": "<span class='fn'>print</span>(<span class='fn'>type</span>(<span class='str'>\"Marco\"</span>))     <span class='cm'># → &lt;class 'str'&gt;</span>\n<span class='fn'>print</span>(<span class='fn'>type</span>(<span class='num'>25</span>))         <span class='cm'># → &lt;class 'int'&gt;</span>\n<span class='fn'>print</span>(<span class='fn'>type</span>(<span class='num'>2500.50</span>))     <span class='cm'># → &lt;class 'float'&gt;</span>\n<span class='fn'>print</span>(<span class='fn'>type</span>(<span class='kw'>True</span>))        <span class='cm'># → &lt;class 'bool'&gt;</span>"}, {"type": "card", "badge": "b-amber", "badgeTxt": "Conversione", "title": "Trasformare un tipo in un altro", "body": "Spesso devi convertire: un CSV ti dà tutto come stringa, ma vuoi fare calcoli. Python ha funzioni dedicate: <code class='inline'>int()</code>, <code class='inline'>float()</code>, <code class='inline'>str()</code>, <code class='inline'>bool()</code>.", "code": "<span class='cm'># CSV → numero (caso classico nel lavoro vero)</span>\n<span class='kw'>prezzo_csv</span> = <span class='str'>\"42.50\"</span>          <span class='cm'># stringa letta da file</span>\n<span class='kw'>prezzo</span> = <span class='fn'>float</span>(<span class='kw'>prezzo_csv</span>)    <span class='cm'># ora è un numero</span>\n<span class='fn'>print</span>(<span class='kw'>prezzo</span> * <span class='num'>1.22</span>)            <span class='cm'># → 51.85 (con IVA)</span>\n\n<span class='cm'># Numero → stringa (per messaggi)</span>\n<span class='kw'>quantità</span> = <span class='num'>15</span>\n<span class='kw'>messaggio</span> = <span class='str'>\"Vendute \"</span> + <span class='fn'>str</span>(<span class='kw'>quantità</span>) + <span class='str'>\" unità\"</span>", "err": "Errore classico: <code class='inline'>\"totale: \" + 100</code> → ERRORE! Non puoi sommare str e int. Devi fare <code class='inline'>\"totale: \" + str(100)</code>. Oppure usare le f-string (prossima lezione)."}, {"type": "editor", "title": "Prova la conversione di tipo", "code": "# Simuliamo un dato letto da un CSV\nprezzo_str = \"42.50\"\nquantità_str = \"15\"\n\n# Converti e calcola\nprezzo = float(prezzo_str)\nquantità = int(quantità_str)\ntotale = prezzo * quantità\n\nprint(f\"Prezzo unitario: €{prezzo:.2f}\")\nprint(f\"Quantità: {quantità}\")\nprint(f\"Totale: €{totale:.2f}\")\nprint(f\"Tipo di totale: {type(totale)}\")"}]}, {"phase": 1, "id": "p1-l3", "phaseName": "Fondamenta", "title": "Operatori — calcoli e confronti", "kicker": "Fase 1 · Lezione 3 di 5", "sub": "Gli operatori sono i simboli che fanno agire Python. Aritmetici per calcolare, di confronto per decidere, logici per combinare.", "content": [{"type": "card", "badge": "b-purple", "badgeTxt": "Aritmetici", "title": "Fare calcoli", "body": "Python fa matematica come una calcolatrice, ma con alcune sottigliezze che devi conoscere.", "opTable": [["Addizione", "+", "10 + 3", "13", "su stringhe concatena"], ["Sottrazione", "-", "10 - 3", "7", ""], ["Moltiplicazione", "*", "10 * 3", "30", "su stringhe ripete"], ["Divisione", "/", "10 / 3", "3.333...", "restituisce sempre float"], ["Divisione intera", "//", "10 // 3", "3", "scarta i decimali"], ["Modulo", "%", "10 % 3", "1", "resto della divisione"], ["Potenza", "**", "2 ** 8", "256", "2 elevato a 8"]], "proTip": "Il modulo <code class='inline'>%</code> è potentissimo per i business analyst: <code class='inline'>n % 2 == 0</code> ti dice se un numero è pari, utile per dividere dati in gruppi alternati, fare sampling, ecc."}, {"type": "card", "badge": "b-teal", "badgeTxt": "Confronto", "title": "Decidere: restituiscono sempre True o False", "body": "Questi operatori sono il cuore di ogni decisione del programma. Il risultato è sempre un booleano.", "code": "<span class='fn'>print</span>(<span class='num'>5</span> > <span class='num'>3</span>)      <span class='cm'># → True   (5 maggiore di 3?)</span>\n<span class='fn'>print</span>(<span class='num'>5</span> < <span class='num'>3</span>)      <span class='cm'># → False  (5 minore di 3?)</span>\n<span class='fn'>print</span>(<span class='num'>5</span> >= <span class='num'>5</span>)     <span class='cm'># → True   (5 ≥ 5?)</span>\n<span class='fn'>print</span>(<span class='num'>5</span> <= <span class='num'>4</span>)     <span class='cm'># → False  (5 ≤ 4?)</span>\n<span class='fn'>print</span>(<span class='num'>5</span> == <span class='num'>5</span>)     <span class='cm'># → True   (5 UGUALE a 5?)</span>\n<span class='fn'>print</span>(<span class='num'>5</span> != <span class='num'>3</span>)     <span class='cm'># → True   (5 DIVERSO da 3?)</span>", "warn": "La differenza più importante di Python:<br><code class='inline'>x = 5</code> → ASSEGNA (metti 5 in x)<br><code class='inline'>x == 5</code> → CONFRONTA (x vale 5?)<br>Usare <code class='inline'>=</code> al posto di <code class='inline'>==</code> è l'errore #1 dei principianti."}, {"type": "editor", "title": "Esplora gli operatori", "code": "a = 17\nb = 5\n\nprint(\"--- ARITMETICI ---\")\nprint(f\"a + b = {a + b}\")\nprint(f\"a - b = {a - b}\")\nprint(f\"a * b = {a * b}\")\nprint(f\"a / b = {a / b}\")    # divisione normale\nprint(f\"a // b = {a // b}\")  # divisione intera\nprint(f\"a % b = {a % b}\")    # resto\nprint(f\"a ** 2 = {a ** 2}\")  # potenza\n\nprint(\"--- CONFRONTI ---\")\nprint(f\"a > b: {a > b}\")\nprint(f\"a == b: {a == b}\")\nprint(f\"a != b: {a != b}\")"}]}, {"phase": 1, "id": "p1-l4", "phaseName": "Fondamenta", "title": "print() e f-string — comunicare", "kicker": "Fase 1 · Lezione 4 di 5", "sub": "print() mostra cose a schermo. Le f-string sono il modo moderno e pulito per costruire messaggi con variabili. Le userai ovunque.", "content": [{"type": "card", "badge": "b-purple", "badgeTxt": "print()", "title": "Tutte le varianti che devi conoscere", "code": "<span class='cm'># 1. Testo fisso</span>\n<span class='fn'>print</span>(<span class='str'>\"Ciao mondo!\"</span>)\n\n<span class='cm'># 2. Valore di una variabile</span>\n<span class='kw'>nome</span> = <span class='str'>\"Marco\"</span>\n<span class='fn'>print</span>(<span class='kw'>nome</span>)                       <span class='cm'># → Marco</span>\n\n<span class='cm'># 3. Più cose separate da spazio</span>\n<span class='fn'>print</span>(<span class='kw'>nome</span>, <span class='str'>\"ha\"</span>, <span class='num'>25</span>, <span class='str'>\"anni\"</span>)       <span class='cm'># → Marco ha 25 anni</span>\n\n<span class='cm'># 4. Separatore personalizzato</span>\n<span class='fn'>print</span>(<span class='str'>\"A\"</span>, <span class='str'>\"B\"</span>, <span class='str'>\"C\"</span>, sep=<span class='str'>\"-\"</span>)        <span class='cm'># → A-B-C</span>\n\n<span class='cm'># 5. Senza andare a capo</span>\n<span class='fn'>print</span>(<span class='str'>\"Caricamento\"</span>, end=<span class='str'>\"...\"</span>)     <span class='cm'># resta sulla stessa riga</span>"}, {"type": "card", "badge": "b-teal", "badgeTxt": "f-string", "title": "Il modo moderno: formatted strings", "body": "Metti una <code class='inline'>f</code> davanti alle virgolette. Le variabili vanno tra <code class='inline'>{}</code>. Python le sostituisce automaticamente.", "code": "<span class='kw'>nome</span> = <span class='str'>\"Marco\"</span>\n<span class='kw'>stipendio</span> = <span class='num'>2500.567</span>\n<span class='kw'>età</span> = <span class='num'>25</span>\n\n<span class='cm'># Vecchio modo (pessimo)</span>\n<span class='fn'>print</span>(<span class='str'>\"Ciao \"</span> + <span class='kw'>nome</span> + <span class='str'>\", stipendio: \"</span> + <span class='fn'>str</span>(<span class='kw'>stipendio</span>))\n\n<span class='cm'># Modo moderno (sempre usa questo)</span>\n<span class='fn'>print</span>(<span class='str'>f\"Ciao {nome}, stipendio: €{stipendio}\"</span>)\n\n<span class='cm'># Puoi fare CALCOLI dentro le parentesi</span>\n<span class='fn'>print</span>(<span class='str'>f\"Fra 10 anni avrò {età + 10} anni\"</span>)\n\n<span class='cm'># FORMATTAZIONE dei numeri</span>\n<span class='fn'>print</span>(<span class='str'>f\"Stipendio: €{stipendio:.2f}\"</span>)      <span class='cm'># 2 decimali: €2500.57</span>\n<span class='fn'>print</span>(<span class='str'>f\"Stipendio: €{stipendio:,.2f}\"</span>)     <span class='cm'># con separatore: €2,500.57</span>\n<span class='fn'>print</span>(<span class='str'>f\"Percentuale: {0.1523:.1%}\"</span>)      <span class='cm'># → 15.2%</span>", "proTip": "Per un business analyst, la formattazione è tutto. <code class='inline'>:,.2f</code> mette il separatore delle migliaia — fondamentale per numeri che vanno in report. <code class='inline'>:.1%</code> formatta come percentuale automaticamente."}, {"type": "editor", "title": "Prova le f-string avanzate", "code": "# Dashboard di un'azienda\nnome_azienda = \"TechCorp SRL\"\nricavi = 1250000.456\nspese = 875000.789\ntasso_crescita = 0.187\n\nprofitto = ricavi - spese\nmargine = profitto / ricavi\n\nprint(f\"=== REPORT {nome_azienda} ===\")\nprint(f\"Ricavi:    €{ricavi:,.2f}\")\nprint(f\"Spese:     €{spese:,.2f}\")\nprint(f\"Profitto:  €{profitto:,.2f}\")\nprint(f\"Margine:   {margine:.1%}\")\nprint(f\"Crescita:  {tasso_crescita:.1%}\")"}]}, {"phase": 1, "id": "p1-l5", "phaseName": "Fondamenta", "title": "Logica booleana — il ragionamento", "kicker": "Fase 1 · Lezione 5 di 5", "sub": "La logica booleana è come il computer pensa. Con and, or, not costruisci regole complesse. Nel business analysis è tutto: filtri, condizioni, KPI.", "content": [{"type": "card", "badge": "b-purple", "badgeTxt": "and", "title": "Entrambe vere", "body": "<code class='inline'>A and B</code> è True SOLO se A e B sono entrambe True. Basta una False per risultare False.", "code": "<span class='fn'>print</span>(<span class='kw'>True</span> <span class='kw'>and</span> <span class='kw'>True</span>)     <span class='cm'># → True</span>\n<span class='fn'>print</span>(<span class='kw'>True</span> <span class='kw'>and</span> <span class='kw'>False</span>)    <span class='cm'># → False</span>\n<span class='fn'>print</span>(<span class='kw'>False</span> <span class='kw'>and</span> <span class='kw'>True</span>)    <span class='cm'># → False</span>\n\n<span class='cm'># Caso business: cliente premium?</span>\n<span class='kw'>spesa_annua</span> = <span class='num'>15000</span>\n<span class='kw'>anni_cliente</span> = <span class='num'>3</span>\n<span class='kw'>è_premium</span> = <span class='kw'>spesa_annua</span> > <span class='num'>10000</span> <span class='kw'>and</span> <span class='kw'>anni_cliente</span> >= <span class='num'>2</span>\n<span class='fn'>print</span>(<span class='kw'>è_premium</span>)                <span class='cm'># → True (entrambi)</span>"}, {"type": "card", "badge": "b-teal", "badgeTxt": "or", "title": "Almeno una vera", "body": "<code class='inline'>A or B</code> è True se ALMENO UNA delle due è True. Diventa False solo se entrambe sono False.", "code": "<span class='fn'>print</span>(<span class='kw'>True</span> <span class='kw'>or</span> <span class='kw'>False</span>)     <span class='cm'># → True</span>\n<span class='fn'>print</span>(<span class='kw'>False</span> <span class='kw'>or</span> <span class='kw'>False</span>)    <span class='cm'># → False</span>\n\n<span class='cm'># Caso business: cliente da contattare?</span>\n<span class='kw'>carrello_abbandonato</span> = <span class='kw'>True</span>\n<span class='kw'>non_acquista_da_mesi</span> = <span class='kw'>False</span>\n<span class='kw'>da_contattare</span> = <span class='kw'>carrello_abbandonato</span> <span class='kw'>or</span> <span class='kw'>non_acquista_da_mesi</span>\n<span class='fn'>print</span>(<span class='kw'>da_contattare</span>)            <span class='cm'># → True</span>"}, {"type": "card", "badge": "b-amber", "badgeTxt": "not", "title": "Inverti il risultato", "code": "<span class='fn'>print</span>(<span class='kw'>not</span> <span class='kw'>True</span>)    <span class='cm'># → False</span>\n<span class='fn'>print</span>(<span class='kw'>not</span> <span class='kw'>False</span>)   <span class='cm'># → True</span>\n\n<span class='cm'># Caso business: escludere i cancellati</span>\n<span class='kw'>cancellato</span> = <span class='kw'>False</span>\n<span class='kw'>attivo</span> = <span class='kw'>not</span> <span class='kw'>cancellato</span>\n<span class='fn'>print</span>(<span class='str'>f\"Cliente attivo: {attivo}\"</span>)"}, {"type": "card", "badge": "b-coral", "badgeTxt": "Combinare", "title": "Regole complesse con parentesi", "body": "Nella pratica combinerai più condizioni. Le parentesi chiariscono la precedenza e rendono il codice leggibile.", "code": "<span class='kw'>stipendio</span> = <span class='num'>3000</span>\n<span class='kw'>anni_azienda</span> = <span class='num'>3</span>\n<span class='kw'>performance</span> = <span class='str'>\"alta\"</span>\n<span class='kw'>in_probation</span> = <span class='kw'>False</span>\n\n<span class='cm'># Eleggibile a promozione SE:</span>\n<span class='cm'># (stipendio alto E anzianità) OPPURE performance alta</span>\n<span class='cm'># E NON in probation</span>\n<span class='kw'>promozione</span> = (\n    (<span class='kw'>stipendio</span> > <span class='num'>2500</span> <span class='kw'>and</span> <span class='kw'>anni_azienda</span> >= <span class='num'>2</span>)\n    <span class='kw'>or</span> <span class='kw'>performance</span> == <span class='str'>\"alta\"</span>\n) <span class='kw'>and</span> <span class='kw'>not</span> <span class='kw'>in_probation</span>\n\n<span class='fn'>print</span>(<span class='str'>f\"Promozione: {promozione}\"</span>)", "proTip": "Spezzare una condizione complessa su più righe con parentesi rende il codice 10 volte più leggibile. I senior lo fanno sempre."}, {"type": "editor", "title": "Costruisci un motore di decisioni", "code": "# Sistema di approvazione credito\nstipendio = 2800\nanni_lavoro = 4\nha_altri_prestiti = False\nètà_cliente = 35\nimporto_richiesto = 15000\n\n# Regola: approvato SE\n# stipendio >= 2000 E anni >= 2 E età tra 25 e 65\n# E (no altri prestiti OPPURE importo < 10000)\napprovato = (\n    stipendio >= 2000\n    and anni_lavoro >= 2\n    and 25 <= ètà_cliente <= 65\n    and (not ha_altri_prestiti or importo_richiesto < 10000)\n)\n\nprint(f\"Stipendio ok: {stipendio >= 2000}\")\nprint(f\"Anni ok: {anni_lavoro >= 2}\")\nprint(f\"Età ok: {25 <= ètà_cliente <= 65}\")\nprint(f\"Credito ok: {not ha_altri_prestiti or importo_richiesto < 10000}\")\nprint(f\"→ APPROVATO: {approvato}\")"}, {"type": "exercises", "title": "Esercizi Fase 1", "exercises": [{"title": "Carta d'identità Python", "tag": "ex-easy", "tagTxt": "Facile", "desc": "Crea 5 variabili su di te (nome, età, altezza, città, lavori) con i tipi giusti. Poi usa f-string per stampare una descrizione completa in 3 righe.", "hint": "Nome e città sono str, età è int, altezza è float, lavori è bool. Usa 3 print(f\"...\") separati.", "solution": "nome = \"Marco\"\netà = 25\naltezza = 1.78\ncittà = \"Bologna\"\nlavora = True\n\nprint(f\"Mi chiamo {nome}, ho {età} anni.\")\nprint(f\"Vivo a {città}, sono alto {altezza}m.\")\nprint(f\"Attualmente lavoro: {lavora}\")"}, {"title": "Calcolatrice stipendio", "tag": "ex-easy", "tagTxt": "Facile", "desc": "Parti da <code class='inline'>stipendio_mensile = 2350</code>. Calcola stipendio annuale, tasse al 23%, netto annuale, netto mensile, quanti mesi servono per raggiungere €10.000 netti (usa divisione intera).", "hint": "annuale = mensile * 12. tasse = annuale * 0.23. netto = annuale - tasse. mesi = 10000 // (netto/12).", "solution": "stipendio_mensile = 2350\nannuale = stipendio_mensile * 12\ntasse = annuale * 0.23\nnetto_annuale = annuale - tasse\nnetto_mensile = netto_annuale / 12\nmesi_per_10k = 10000 // netto_mensile\n\nprint(f\"Annuale lordo: €{annuale:,.2f}\")\nprint(f\"Tasse (23%):   €{tasses:,.2f}\")\nprint(f\"Netto annuale: €{netto_annuale:,.2f}\")\nprint(f\"Netto mensile: €{netto_mensile:,.2f}\")\nprint(f\"Mesi per 10k:  {int(mesi_per_10k)}\")"}, {"title": "Accesso al sistema", "tag": "ex-med", "tagTxt": "Medio", "desc": "Regola: un utente entra SOLO SE ha account attivo AND (è admin OR ha credito ≥ 10€) AND non è bloccato. Dati: <code class='inline'>attivo=True, è_admin=False, credito=15.0, bloccato=False</code>. Stampa ogni sotto-condizione e il risultato finale.", "hint": "Definisci le sotto-condizioni come variabili separate (es. ha_credito = credito >= 10), così puoi stamparle. Poi combina con and/or.", "solution": "attivo = True\nè_admin = False\ncredito = 15.0\nbloccato = False\n\nha_credito = credito >= 10\naccesso = attivo and (è_admin or ha_credito) and not bloccato\n\nprint(f\"Attivo: {attivo}\")\nprint(f\"Admin o credito: {è_admin or ha_credito}\")\nprint(f\"Non bloccato: {not bloccato}\")\nprint(f\"→ ACCESSO: {accesso}\")"}, {"title": "Report vendite negozio", "tag": "ex-biz", "tagTxt": "Business", "desc": "Sei l'analista del negozio. Dati: unità vendute=143, prezzo unitario=42.50, costo unitario=28.00, spese fisse=800, target mensile=5000. Calcola e stampa: ricavi, costi totali, profitto, margine %, se è in utile, se ha raggiunto il target.", "hint": "ricavi=unità*prezzo. costi_var=unità*costo. costi_tot=costi_var+spese_fisse. profitto=ricavi-costi_tot. margine=profitto/ricavi. in_utile=profitto>0. target_ok=profitto>=5000.", "solution": "unità = 143\nprezzo = 42.50\ncosto = 28.00\nspese_fisse = 800\ntarget = 5000\n\nricavi = unità * prezzo\ncosti_var = unità * costo\ncosti_tot = costi_var + spese_fisse\nprofitto = ricavi - costi_tot\nmargine = profitto / ricavi\n\nprint(f\"Ricavi:   €{ricavi:,.2f}\")\nprint(f\"Costi:    €{costi_tot:,.2f}\")\nprint(f\"Profitto: €{profitto:,.2f}\")\nprint(f\"Margine:  {margine:.1%}\")\nprint(f\"In utile: {profitto > 0}\")\nprint(f\"Target OK: {profitto >= target}\")"}]}]}, {"phase": 1, "id": "p1-ex", "phaseName": "Fondamenta", "title": "Esercizi Fase 1 — Fondamenta", "kicker": "Fase 1 · Esercizi pratici", "sub": "Quattro esercizi per consolidare variabili, tipi, operatori, print e logica booleana. Prima prova da solo. Se sei bloccato, apri l'aiuto. Solo alla fine guarda la soluzione.", "content": [{"type": "exercise", "tag": "ex-easy", "title": "1. Carta d'identità Python", "desc": "Crea 5 variabili con i tuoi dati (nome, età, altezza, città, lavori). Poi stampa 3 righe formattate con f-string.<br><br><strong>Output atteso (esempio):</strong><br><code class='inline'>Mi chiamo Marco, ho 25 anni</code><br><code class='inline'>Vivo a Bologna, alto 1.80m</code><br><code class='inline'>Lavoro: True</code>", "code": "# Scrivi qui il tuo codice\n", "hint": "Usa snake_case per i nomi. Le f-string iniziano con f: <code class='inline'>f\"Ciao {nome}\"</code>. Per i decimali: <code class='inline'>{altezza:.2f}</code>", "solution": "nome = \"Marco\"\netà = 25\naltezza = 1.80\ncittà = \"Bologna\"\nlavora = True\n\nprint(f\"Mi chiamo {nome}, ho {età} anni\")\nprint(f\"Vivo a {città}, alto {altezza:.2f}m\")\nprint(f\"Lavoro: {lavora}\")"}, {"type": "exercise", "tag": "ex-easy", "title": "2. Calcolatrice stipendio", "desc": "Dato uno stipendio mensile di 2350€, calcola e stampa: annuale lordo, tasse (23%), netto annuale, netto mensile (arrotondato a 2 decimali), quanti anni servono per risparmiare 50.000€ mettendo via il 20% del netto.", "code": "stipendio_mensile = 2350\n\n# Calcola:\n# - lordo_annuale\n# - tasse (23%)\n# - netto_annuale\n# - netto_mensile\n# - anni per raggiungere 50000 risparmiando il 20%\n", "hint": "Tasse = lordo * 0.23. Netto = lordo - tasse. Risparmio annuo = netto * 0.20. Anni = 50000 / risparmio_annuo. Usa <code class='inline'>:.2f</code> per i decimali, <code class='inline'>:.1f</code> per gli anni.", "solution": "stipendio_mensile = 2350\nlordo_annuale = stipendio_mensile * 12\ntasse = lordo_annuale * 0.23\nnetto_annuale = lordo_annuale - tasse\nnetto_mensile = netto_annuale / 12\nrisparmio_annuo = netto_annuale * 0.20\nanni_target = 50000 / risparmio_annuo\n\nprint(f\"Lordo annuale: €{lordo_annuale:.2f}\")\nprint(f\"Tasse 23%: €{tasse:.2f}\")\nprint(f\"Netto annuale: €{netto_annuale:.2f}\")\nprint(f\"Netto mensile: €{netto_mensile:.2f}\")\nprint(f\"Anni per 50k€: {anni_target:.1f}\")"}, {"type": "exercise", "tag": "ex-med", "title": "3. Controllo accesso sistema", "desc": "Un utente accede SOLO SE: ha account attivo AND (è admin OR credito ≥ 10) AND non è bloccato. Crea le variabili, calcola il permesso, stampa un report dettagliato spiegando ciascuna condizione.", "code": "attivo = True\nè_admin = False\ncredito = 15.0\nbloccato = False\n\n# Calcola il permesso e stampa dettagli per ogni condizione\n", "hint": "Usa parentesi per raggruppare: <code class='inline'>attivo and (è_admin or credito >= 10) and not bloccato</code>. Stampa ogni condizione con f-string per capire quale True/False porta al risultato.", "solution": "attivo = True\nè_admin = False\ncredito = 15.0\nbloccato = False\n\nha_credito = credito >= 10\npuò_accedere = attivo and (è_admin or ha_credito) and not bloccato\n\nprint(f\"Account attivo: {attivo}\")\nprint(f\"Admin: {è_admin}\")\nprint(f\"Credito sufficiente (>=10): {ha_credito}\")\nprint(f\"Bloccato: {bloccato}\")\nprint(f\"---\")\nprint(f\"ACCESSO CONSENTITO: {può_accedere}\")"}, {"type": "exercise", "tag": "ex-biz", "title": "4. Report vendite (mindset BA)", "desc": "Sei il BA di un negozio. Dati: 143 unità vendute a 42.50€ l'una, costo unitario 28€, spese fisse 800€. Calcola e stampa un report professionale con: ricavi, costo variabile, costo totale, profitto, margine % sul fatturato, se è in utile, se ha raggiunto il target di 4000€ di profitto.", "code": "unità = 143\nprezzo = 42.50\ncosto_unitario = 28.0\nspese_fisse = 800\ntarget = 4000\n\n# Calcola tutte le metriche e stampa il report\n", "hint": "ricavi=unità*prezzo; costo_var=unità*costo_unitario; costo_tot=costo_var+spese_fisse; profitto=ricavi-costo_tot; margine=(profitto/ricavi)*100. Poi booleani: in_utile=profitto>0; target_ok=profitto>=target.", "solution": "unità = 143\nprezzo = 42.50\ncosto_unitario = 28.0\nspese_fisse = 800\ntarget = 4000\n\nricavi = unità * prezzo\ncosto_variabile = unità * costo_unitario\ncosto_totale = costo_variabile + spese_fisse\nprofitto = ricavi - costo_totale\nmargine = (profitto / ricavi) * 100\nin_utile = profitto > 0\ntarget_raggiunto = profitto >= target\n\nprint(\"=== REPORT VENDITE ===\")\nprint(f\"Ricavi: €{ricavi:.2f}\")\nprint(f\"Costo variabile: €{costo_variabile:.2f}\")\nprint(f\"Spese fisse: €{spese_fisse:.2f}\")\nprint(f\"Costo totale: €{costo_totale:.2f}\")\nprint(f\"Profitto: €{profitto:.2f}\")\nprint(f\"Margine: {margine:.1f}%\")\nprint(f\"In utile: {in_utile}\")\nprint(f\"Target raggiunto: {target_raggiunto}\")"}]}, {"phase": 2, "id": "p2-l1", "phaseName": "Strutture dati", "title": "Liste — collezioni ordinate", "kicker": "Fase 2 · Lezione 1 di 5", "sub": "Una lista è una collezione ordinata di valori. È la struttura dati più usata in Python. Nel lavoro vero, è un'intera colonna di un report, una sequenza di transazioni, i mesi dell'anno.", "content": [{"type": "card", "badge": "b-purple", "badgeTxt": "Creare liste", "body": "Le liste si creano con le <strong>parentesi quadre</strong> <code class='inline'>[]</code> e gli elementi separati da virgole. Possono contenere qualsiasi tipo di valore, anche mescolati.", "code": "<span class='cm'># Lista di numeri (tipica nel lavoro)</span>\n<span class='kw'>vendite</span> = [<span class='num'>120</span>, <span class='num'>85</span>, <span class='num'>200</span>, <span class='num'>150</span>, <span class='num'>90</span>]\n\n<span class='cm'># Lista di stringhe</span>\n<span class='kw'>mesi</span> = [<span class='str'>\"gen\"</span>, <span class='str'>\"feb\"</span>, <span class='str'>\"mar\"</span>, <span class='str'>\"apr\"</span>]\n\n<span class='cm'># Lista vuota (da riempire dopo)</span>\n<span class='kw'>clienti</span> = []\n\n<span class='cm'># Lista mista (meno comune ma valida)</span>\n<span class='kw'>record</span> = [<span class='str'>\"Marco\"</span>, <span class='num'>25</span>, <span class='kw'>True</span>, <span class='num'>2500.50</span>]"}, {"type": "card", "badge": "b-teal", "badgeTxt": "Indici", "title": "Accedere agli elementi", "body": "Gli elementi di una lista si numerano da <strong>0</strong>, non da 1. È fondamentale ricordarlo: il primo elemento è <code class='inline'>lista[0]</code>, non <code class='inline'>lista[1]</code>.", "code": "<span class='kw'>vendite</span> = [<span class='num'>120</span>, <span class='num'>85</span>, <span class='num'>200</span>, <span class='num'>150</span>, <span class='num'>90</span>]\n<span class='cm'>#              0    1    2    3    4       ← indici</span>\n\n<span class='fn'>print</span>(<span class='kw'>vendite</span>[<span class='num'>0</span>])     <span class='cm'># → 120 (primo)</span>\n<span class='fn'>print</span>(<span class='kw'>vendite</span>[<span class='num'>2</span>])     <span class='cm'># → 200 (terzo)</span>\n<span class='fn'>print</span>(<span class='kw'>vendite</span>[-<span class='num'>1</span>])    <span class='cm'># → 90 (ultimo)</span>\n<span class='fn'>print</span>(<span class='kw'>vendite</span>[-<span class='num'>2</span>])    <span class='cm'># → 150 (penultimo)</span>", "proTip": "Gli indici <strong>negativi</strong> sono una scorciatoia geniale: <code class='inline'>-1</code> è sempre l'ultimo elemento, <code class='inline'>-2</code> il penultimo. Non devi sapere la lunghezza della lista."}, {"type": "card", "badge": "b-amber", "badgeTxt": "Slicing", "title": "Prendere una fetta di lista", "body": "Con <code class='inline'>lista[start:stop]</code> prendi una fetta. <strong>Start è incluso, stop è escluso</strong>. Ti sembrerà strano all'inizio, ma c'è una logica.", "code": "<span class='kw'>vendite</span> = [<span class='num'>120</span>, <span class='num'>85</span>, <span class='num'>200</span>, <span class='num'>150</span>, <span class='num'>90</span>]\n\n<span class='fn'>print</span>(<span class='kw'>vendite</span>[<span class='num'>0</span>:<span class='num'>3</span>])    <span class='cm'># [120, 85, 200] primi 3</span>\n<span class='fn'>print</span>(<span class='kw'>vendite</span>[:<span class='num'>3</span>])     <span class='cm'># stessa cosa (0 implicito)</span>\n<span class='fn'>print</span>(<span class='kw'>vendite</span>[<span class='num'>2</span>:])     <span class='cm'># [200, 150, 90] dal 3° alla fine</span>\n<span class='fn'>print</span>(<span class='kw'>vendite</span>[-<span class='num'>2</span>:])    <span class='cm'># [150, 90] ultimi 2</span>\n<span class='fn'>print</span>(<span class='kw'>vendite</span>[::<span class='num'>2</span>])    <span class='cm'># [120, 200, 90] ogni 2</span>\n<span class='fn'>print</span>(<span class='kw'>vendite</span>[::-<span class='num'>1</span>])   <span class='cm'># [90, 150, 200, 85, 120] invertita!</span>"}, {"type": "card", "badge": "b-blue", "badgeTxt": "Metodi", "title": "Modificare una lista", "body": "Le liste sono <strong>mutabili</strong>: puoi modificarle. Ecco i metodi che userai sempre.", "opTable": [["append(x)", "", "lista.append(5)", "aggiunge 5 alla fine", ""], ["insert(i, x)", "", "lista.insert(0, 5)", "inserisce in posizione i", ""], ["remove(x)", "", "lista.remove(5)", "rimuove la prima occorrenza di 5", ""], ["pop()", "", "lista.pop()", "rimuove e restituisce l'ultimo", ""], ["sort()", "", "lista.sort()", "ordina in-place", ""], ["reverse()", "", "lista.reverse()", "inverte in-place", ""], ["len(lista)", "", "len(lista)", "lunghezza (è una funzione)", ""]]}, {"type": "editor", "title": "Operazioni con liste", "code": "# Vendite della settimana (lun-dom)\nvendite = [120, 85, 200, 150, 90, 180, 220]\ngiorni = [\"lun\", \"mar\", \"mer\", \"gio\", \"ven\", \"sab\", \"dom\"]\n\nprint(f\"Totale settimana: €{sum(vendite)}\")\nprint(f\"Media giornaliera: €{sum(vendite)/len(vendite):.2f}\")\nprint(f\"Giorno migliore: {max(vendite)}\")\nprint(f\"Giorno peggiore: {min(vendite)}\")\n\n# Primi 3 giorni\nprint(f\"Prima metà: {vendite[:3]}\")\n\n# Ultimi 2 giorni\nprint(f\"Weekend: {vendite[-2:]}\")\n\n# Aggiungi un giorno\nvendite.append(250)\nprint(f\"Con lunedì prossimo: {vendite}\")"}]}, {"phase": 2, "id": "p2-l2", "phaseName": "Strutture dati", "title": "Dizionari — dati con etichette", "kicker": "Fase 2 · Lezione 2 di 5", "sub": "Un dizionario associa una chiave a un valore. È come una scheda strutturata. Nel lavoro vero è una riga di un database, un record cliente, un oggetto JSON ricevuto da un'API.", "content": [{"type": "card", "badge": "b-purple", "badgeTxt": "Creare dizionari", "body": "I dizionari usano le <strong>parentesi graffe</strong> <code class='inline'>{}</code>, con coppie <code class='inline'>chiave: valore</code> separate da virgole. Le chiavi sono uniche (non si possono ripetere).", "code": "<span class='cm'># Record di un cliente (JSON-like)</span>\n<span class='kw'>cliente</span> = {\n    <span class='str'>\"nome\"</span>: <span class='str'>\"Marco Rossi\"</span>,\n    <span class='str'>\"età\"</span>: <span class='num'>34</span>,\n    <span class='str'>\"email\"</span>: <span class='str'>\"marco@example.com\"</span>,\n    <span class='str'>\"spesa_totale\"</span>: <span class='num'>15420.50</span>,\n    <span class='str'>\"premium\"</span>: <span class='kw'>True</span>\n}\n\n<span class='cm'># Accedi con la chiave, non con l'indice!</span>\n<span class='fn'>print</span>(<span class='kw'>cliente</span>[<span class='str'>\"nome\"</span>])           <span class='cm'># → Marco Rossi</span>\n<span class='fn'>print</span>(<span class='kw'>cliente</span>[<span class='str'>\"spesa_totale\"</span>])   <span class='cm'># → 15420.50</span>", "warn": "Le liste usano indici numerici (<code class='inline'>lista[0]</code>). I dizionari usano le chiavi stringa (<code class='inline'>dict[\"nome\"]</code>). Non confonderli."}, {"type": "card", "badge": "b-teal", "badgeTxt": "Modificare", "title": "Aggiungere, cambiare, rimuovere", "code": "<span class='kw'>cliente</span> = {<span class='str'>\"nome\"</span>: <span class='str'>\"Marco\"</span>, <span class='str'>\"età\"</span>: <span class='num'>34</span>}\n\n<span class='cm'># Aggiungere o modificare</span>\n<span class='kw'>cliente</span>[<span class='str'>\"città\"</span>] = <span class='str'>\"Bologna\"</span>       <span class='cm'># aggiunge</span>\n<span class='kw'>cliente</span>[<span class='str'>\"età\"</span>] = <span class='num'>35</span>                 <span class='cm'># modifica</span>\n\n<span class='cm'># Rimuovere</span>\n<span class='kw'>del</span> <span class='kw'>cliente</span>[<span class='str'>\"città\"</span>]\n\n<span class='cm'># Accesso sicuro (non fa errore se manca)</span>\n<span class='fn'>print</span>(<span class='kw'>cliente</span>.<span class='fn'>get</span>(<span class='str'>\"telefono\"</span>))              <span class='cm'># → None</span>\n<span class='fn'>print</span>(<span class='kw'>cliente</span>.<span class='fn'>get</span>(<span class='str'>\"telefono\"</span>, <span class='str'>\"N/D\"</span>))       <span class='cm'># → N/D</span>", "proTip": "Usa sempre <code class='inline'>.get(chiave, default)</code> invece di <code class='inline'>dict[chiave]</code> quando non sei sicuro che la chiave esista. Evita crash quando lavori con dati di API o CSV imperfetti."}, {"type": "card", "badge": "b-amber", "badgeTxt": "Esplorare", "title": "Chiavi, valori, coppie", "code": "<span class='kw'>vendite_mese</span> = {<span class='str'>\"gen\"</span>: <span class